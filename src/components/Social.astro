---
const { platform, username } = Astro.props as { platform: string | number; username: string | number };
const platformStr = String(platform);
const usernameStr = String(username);

const urlMap: Record<string, string> = {
  github: `https://github.com/${username}`,
  twitter: `https://twitter.com/${username}`,
  bilibili: `https://space.bilibili.com/${username}`,
  zhihu: `https://www.zhihu.com/people/${username}`,
  douban: `https://www.douban.com/people/${username}/`,
};

const url = urlMap[platform] || `https://www.${platform}.com/${username}`;
---

<a href={url} target="_blank" rel="noopener noreferrer">
  {platform}
</a>

<style>
  a {
    padding: 0.5rem 1rem;
    color: white;
    background-color: #4c1d95;
    text-decoration: none;
  }
</style>